# ── Datastores ────────────────────────────────────────────────────────
POLARIS_DATABASE_URL=postgresql+asyncpg://root:123456@127.0.0.1:5432/polaris
POLARIS_REDIS_URL=redis://127.0.0.1:6379/0

# ── Workspace storage roots (optional overrides) ──────────────────────
# Commented out: pydantic-settings uses the baked-in defaults
# (`<repo>/.data/workspaces` and `<repo>/.data/workspace-meta`).  Setting
# these to an EMPTY STRING would override those defaults to "" — don't.
# `/tmp/...` is tmpfs on many distros and will lose user repos on reboot.
# POLARIS_WORKSPACE_ROOT=<absolute path to user git checkouts>
# POLARIS_WORKSPACE_META_ROOT=<absolute path to per-workspace compose + browser-config>

# ── Session / auth ─────────────────────────────────────────────────────
SESSION_SECRET=replace-with-a-random-64-byte-secret
# SESSION_TTL_DAYS=7

# ── Dev Login shortcut (LOCAL DEV ONLY) ────────────────────────────────
# When both are set, GET /auth/dev-login auto-provisions + signs in as
# this email, and the frontend shows a "Dev Login" button.  Leave empty
# (or unset) on any shared / staging / prod host — the endpoint 404s
# and the button is hidden via `GET /auth/config`.
POLARIS_DEV_USER_EMAIL=dev@polaris.local
POLARIS_DEV_USER_NAME=Polaris Dev

# ── Email verification (Postmark) ──────────────────────────────────────
# Empty POSTMARK_SERVER_TOKEN → codes log to the API console (dev).
POSTMARK_SERVER_TOKEN=
POSTMARK_MESSAGE_STREAM=outbound
POSTMARK_FROM_EMAIL=noreply@polaris.dev

# ── Invite code (sign-up gate) ─────────────────────────────────────────
# Exactly 6 digits ([0-9]{6}) — the sign-up schema rejects anything else.
# Empty = no new user can register.  Rotate if leaked.
POLARIS_INVITE_CODE=

# ── Frontend ──────────────────────────────────────────────────────────
FRONTEND_URL=https://polaris-dev.xyz
POLARIS_CORS_ORIGINS=["https://polaris-dev.xyz"]
VITE_API_BASE_URL=/api

# ── Domains (Traefik) ─────────────────────────────────────────────────
# Override when deploying under your own domain.  See docs/STAGING.md
# for the four zones (platform / prod / ide / browser / s3) Traefik
# needs to route.
# POLARIS_DOMAIN=polaris-dev.xyz
# POLARIS_PROD_DOMAIN_BASE=prod.polaris-dev.xyz
# POLARIS_TRAEFIK_PUBLIC_NETWORK=traefik-public

# ── Workspace / browser public URL templates ──────────────────────────
POLARIS_IDE_PUBLIC_URL_TEMPLATE=https://ide-{workspaceHash}.polaris-dev.xyz
POLARIS_BROWSER_PUBLIC_URL_TEMPLATE=https://browser-{workspaceHash}.polaris-dev.xyz

# ── Container images ──────────────────────────────────────────────────
POLARIS_WORKSPACE_IMAGE=polaris/workspace:latest
POLARIS_BROWSER_IMAGE=polaris/chromium-vnc:latest
POLARIS_POSTGRES_IMAGE=postgres:16-alpine
POLARIS_REDIS_IMAGE=redis:7-alpine

# ── Codex auth (host bind-mount for in-workspace codex app-server) ────
# Leave unset to use the default (`$HOME/.codex/auth.json`).  Do NOT set
# to "" — that overrides the default to an empty path.
# POLARIS_HOST_CODEX_AUTH_PATH=<absolute path to auth.json>

# ── Worker / Codex runtime ────────────────────────────────────────────
POLARIS_CODEX_MODEL=gpt-5.4
# POLARIS_CODEX_TURN_TIMEOUT_SECONDS=900       # hard wall-clock cap per turn
# POLARIS_CODEX_LIVENESS_CHECK_INTERVAL_SECONDS=30
# POLARIS_CODEX_PLAN_PLAIN_MODEL=gpt-5.4       # plan → non-technical Overview translator
# POLARIS_IDLE_WORKSPACE_TIMEOUT_SECONDS=3600  # scavenger stops idle workspaces

# ── MinIO (S3-compatible object store; infra/minio/compose.yaml) ──────
MINIO_ROOT_USER=root
MINIO_ROOT_PASSWORD=replace-with-a-random-32-byte-secret

# ── S3 target (reads MinIO credentials above in dev) ──────────────────
# `static/*` key prefix is anonymously readable; built URLs are
# `${S3_URL_BASE}/${key}`.  Credentials stay platform-side.
S3_ACCESS_KEY_ID=polaris
S3_SECRET_ACCESS_KEY=
S3_ENDPOINT=https://s3.polaris-dev.xyz
S3_BUCKET=polaris
S3_URL_BASE=https://polaris.s3.polaris-dev.xyz

# ── Unsplash MCP (server-side only; the workspace MCP proxies via /mcp) ──
UNSPLASH_ACCESS_KEY=

# ── Design-intent pre-agent (LangGraph; see packages/design-intent/) ──
OPENAI_SECRET=
# Per-role model overrides.  Compiler + clarifier are quality-critical
# (multimodal design brief + multi-round tool calls) → flagship defaults;
# review + scorer are cheap structured calls → -mini defaults.
POLARIS_DESIGN_INTENT_COMPILER_MODEL=gpt-5.4
POLARIS_DESIGN_INTENT_CLARIFIER_MODEL=gpt-5.4-mini
POLARIS_DESIGN_INTENT_REVIEW_MODEL=gpt-5.4-mini
# POLARIS_DESIGN_INTENT_SCORER_MODEL=gpt-5.4-mini
# POLARIS_DESIGN_INTENT_MOOD_BOARD_IMAGE_MODEL=gpt-image-1
# POLARIS_DESIGN_INTENT_MOOD_BOARD_SIZE=1536x1024
POLARIS_PINTEREST_TOOL_BASE=http://polaris-dev.xyz:9801
POLARIS_DESIGN_INTENT_MAX_ROUNDS=3
POLARIS_DESIGN_INTENT_PINTEREST_HOPS=1
# Candidates sent to the batched scorer.  Downed from 12 → 6 to save
# multimodal token cost; 6 consistently surfaces a ≥ threshold match.
POLARIS_DESIGN_INTENT_MAX_REFS=6
# Upper bound for images piped to the compiler.  Pipeline now forces a
# single best-scored image through; this knob is kept for future
# multi-image compile experiments but effectively capped at 1.
POLARIS_DESIGN_INTENT_MAX_IMAGES_TO_COMPILER=6
# POLARIS_DESIGN_INTENT_IMAGE_SCORE_THRESHOLD=4.0   # 0–5; first hit ≥ threshold wins

# ── Prepublish LLM audit (`polaris prepublish-audit --deep`) ──────────
# POLARIS_AUDIT_MODEL=gpt-5.4-mini

# ── Publish pipeline ──────────────────────────────────────────────────
# POLARIS_PUBLISH_PROJECTS_ROOT=<absolute path to .data/projects/>
# POLARIS_REGISTRY_URL=127.0.0.1:5000
# POLARIS_API_URL_FOR_WORKSPACE=http://host.docker.internal:8000
# POLARIS_PUBLISH_BUILD_TIMEOUT=900                 # docker build wall-clock (s)
# POLARIS_PUBLISH_SMOKE_TIMEOUT=60                  # smoke probe window (s)

# ── Run concurrency quota ──────────────────────────────────────────────
# Caps in-flight Sessions so a single user opening multiple tabs can't
# balloon OpenAI + gpt-image-1 spend.  Acquired at POST /sessions and
# released in the worker's finally block.  TTL is a crash-recovery
# backstop (expired entries get purged on the next acquire).
POLARIS_MAX_GLOBAL_RUNS=6
POLARIS_MAX_USER_RUNS=2
POLARIS_RUN_QUOTA_TTL_SECONDS=1800
